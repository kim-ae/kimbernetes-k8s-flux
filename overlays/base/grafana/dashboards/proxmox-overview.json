{
  "title": "Proxmox Overview (pve-exporter)",
  "uid": "proxmox-overview",
  "tags": [
    "proxmox",
    "pve-exporter"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "node",
        "type": "query",
        "label": "Proxmox Node",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "label_values(pve_node_info, name)",
          "refId": "node-variable"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Host Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Node Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "pve_up{id=\"node/$node\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "CPU Usage",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "pve_cpu_usage_ratio{id=\"node/$node\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Memory Usage",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pve_memory_usage_bytes{id=\"node/$node\"} / pve_memory_size_bytes{id=\"node/$node\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Root Disk Usage",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pve_disk_usage_bytes{id=\"node/$node\"} / pve_disk_size_bytes{id=\"node/$node\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 3, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "pve_uptime_seconds{id=\"node/$node\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "dtdurations" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "PVE Version",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "pve_version_info", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Value": true, "__name__": true, "job": true, "instance": true,
              "release": true, "repoid": true
            },
            "renameByName": { "version": "PVE Version" }
          }
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^PVE Version$/" },
        "textMode": "value",
        "colorMode": "none",
        "graphMode": "none"
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Node CPU Usage",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pve_cpu_usage_ratio{id=\"node/$node\"}",
          "refId": "A",
          "legendFormat": "CPU usage"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Node Memory Usage",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pve_memory_usage_bytes{id=\"node/$node\"}",
          "refId": "A",
          "legendFormat": "Used"
        },
        {
          "expr": "pve_memory_size_bytes{id=\"node/$node\"}",
          "refId": "B",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 200,
      "type": "row",
      "title": "VMs & Containers",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "type": "table",
      "title": "Guests Overview",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pve_guest_info{node=\"$node\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_up{id=~\"(qemu|lxc)/.*\"}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_cpu_usage_ratio{id=~\"(qemu|lxc)/.*\"}",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_memory_usage_bytes{id=~\"(qemu|lxc)/.*\"} / pve_memory_size_bytes{id=~\"(qemu|lxc)/.*\"}",
          "refId": "D",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_disk_usage_bytes{id=~\"(qemu|lxc)/.*\"} / pve_disk_size_bytes{id=~\"(qemu|lxc)/.*\"}",
          "refId": "E",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_uptime_seconds{id=~\"(qemu|lxc)/.*\"}",
          "refId": "F",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "Time 6": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true, "__name__ 6": true,
              "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true, "job 6": true,
              "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "instance 5": true, "instance 6": true,
              "node": true, "tags": true, "template": true
            },
            "renameByName": {
              "name": "Name",
              "type": "Type",
              "Value #B": "Status",
              "Value #C": "CPU",
              "Value #D": "Memory",
              "Value #E": "Disk",
              "Value #F": "Uptime",
              "id": "ID"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "STOPPED", "color": "red" }, "1": { "text": "RUNNING", "color": "green" } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Memory" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Disk" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [
              { "id": "unit", "value": "dtdurations" }
            ]
          }
        ]
      },
      "options": { "showHeader": true }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Guest CPU Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pve_cpu_usage_ratio{id=~\"(qemu|lxc)/.*\"} * on(id) group_left(name) pve_guest_info{node=\"$node\"}",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Guest Memory Usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(pve_memory_usage_bytes{id=~\"(qemu|lxc)/.*\"} / pve_memory_size_bytes{id=~\"(qemu|lxc)/.*\"}) * on(id) group_left(name) pve_guest_info{node=\"$node\"}",
          "refId": "A",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Storage",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "type": "table",
      "title": "Storage Overview",
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pve_storage_info{node=\"$node\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_disk_size_bytes{id=~\"storage/.*\"}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_disk_usage_bytes{id=~\"storage/.*\"}",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "pve_storage_shared{id=~\"storage/.*\"}",
          "refId": "D",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "calculateField",
          "options": {
            "mode": "binary",
            "binary": { "left": "Value #C", "operator": "/", "right": "Value #B" },
            "alias": "Used %"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true,
              "job 1": true, "job 2": true, "job 3": true, "job 4": true,
              "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true,
              "node": true, "id": true, "content": true
            },
            "renameByName": {
              "storage": "Storage",
              "plugintype": "Type",
              "Value #B": "Size",
              "Value #C": "Used",
              "Value #D": "Shared"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Size" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "Used" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          {
            "matcher": { "id": "byName", "options": "Used %" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "custom.displayMode", "value": "gradient-gauge" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Shared" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "No" }, "1": { "text": "Yes" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": { "showHeader": true }
    },
    {
      "id": 31,
      "type": "bargauge",
      "title": "Storage Usage %",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(pve_disk_usage_bytes{id=~\"storage/.*\"} / pve_disk_size_bytes{id=~\"storage/.*\"}) * on(id) group_left(storage) pve_storage_info{node=\"$node\"}",
          "refId": "A",
          "instant": true,
          "legendFormat": "{{storage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
