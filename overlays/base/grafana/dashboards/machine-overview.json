    {
      "id": 200,
      "type": "row",
      "title": "CPU",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Usage by Mode",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{machine_name=\"$machine\"}[$__rate_interval])) * 100",
          "refId": "A",
          "legendFormat": "{{mode}}",
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 11,
      "type": "gauge",
      "title": "Current CPU Busy %",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\", machine_name=\"$machine\"}[5m])) * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 300,
      "type": "row",
      "title": "Memory",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {
        "h": 8,
        "w": 18,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{machine_name=\"$machine\"}",
          "refId": "A",
          "legendFormat": "Total"
        },
        {
          "expr": "node_memory_MemTotal_bytes{machine_name=\"$machine\"} - node_memory_MemAvailable_bytes{machine_name=\"$machine\"}",
          "refId": "B",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{machine_name=\"$machine\"}",
          "refId": "C",
          "legendFormat": "Available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 21,
      "type": "gauge",
      "title": "Memory Usage %",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{machine_name=\"$machine\"} / node_memory_MemTotal_bytes{machine_name=\"$machine\"})) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 400,
      "type": "row",
      "title": "Disk & Filesystem",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Disk I/O (bytes/s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{machine_name=\"$machine\"}[$__rate_interval])",
          "refId": "A",
          "legendFormat": "{{device}} read",
          "interval": "30s"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{machine_name=\"$machine\"}[$__rate_interval])",
          "refId": "B",
          "legendFormat": "{{device}} write",
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 31,
      "type": "bargauge",
      "title": "Filesystem Usage % by Mount Point",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{machine_name=\"$machine\", fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{machine_name=\"$machine\", fstype!~\"tmpfs|overlay|squashfs\"})) * 100",
          "refId": "A",
          "legendFormat": "{{mountpoint}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal"
      }
    },
    {
      "id": 500,
      "type": "row",
      "title": "Network",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "Network Traffic (bytes/s)",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{machine_name=\"$machine\", device!=\"lo\"}[$__rate_interval])",
          "refId": "A",
          "legendFormat": "{{device}} rx",
          "interval": "30s"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{machine_name=\"$machine\", device!=\"lo\"}[$__rate_interval])",
          "refId": "B",
          "legendFormat": "{{device}} tx",
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "id": 41,
      "type": "table",
      "title": "Network Interfaces",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 33
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "node_network_up{machine_name=\"$machine\", device!=\"lo\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "instance": true,
              "machine_name": true,
              "__name__": true
            },
            "renameByName": {
              "device": "Interface",
              "Value": "Up"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 600,
      "type": "row",
      "title": "systemd",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 50,
      "type": "table",
      "title": "systemd Units (running/active)",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "node_systemd_unit_state{machine_name=\"$machine\", state=\"active\"} == 1",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "job": true,
              "instance": true,
              "machine_name": true,
              "namespace": true,
              "service": true,
              "endpoint": true,
              "__name__": true
