              "machine_name": true, "sysname": true, "nodename": true, "domainname": true,
              "machine": true, "version": true
            },
            "renameByName": { "release": "Kernel Release" }
          }
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^Kernel Release$/" },
        "textMode": "value",
        "colorMode": "none",
        "graphMode": "none"
      }
    },
