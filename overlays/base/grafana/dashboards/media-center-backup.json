{
  "title": "Media Center Backup",
  "uid": "media-center-backup",
  "tags": ["media-center", "backup", "node-exporter"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-30d", "to": "now" },
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {},
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Last Run Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "media_backup_last_run_success{machine_name=\"media-center\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "SUCCESS", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Last Run Time",
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "media_backup_last_run_timestamp_seconds{machine_name=\"media-center\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "dateTimeAsLocal" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "none" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Time Since Last Run",
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "time() - media_backup_last_run_timestamp_seconds{machine_name=\"media-center\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 604800 }, { "color": "red", "value": 691200 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Run Duration",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "media_backup_last_run_duration_seconds{machine_name=\"media-center\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "none" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Timer Active",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "node_systemd_unit_state{machine_name=\"media-center\", name=\"media-backup.timer\", state=\"active\"}", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "INACTIVE", "color": "red" }, "1": { "text": "ACTIVE", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value", "colorMode": "background" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Backup Success History",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "media_backup_last_run_success{machine_name=\"media-center\"}", "refId": "A", "legendFormat": "success (1=ok, 0=failed)" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0, "max": 1,
          "custom": { "drawStyle": "points", "pointSize": 8, "spanNulls": false }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Backup Duration History",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "media_backup_last_run_duration_seconds{machine_name=\"media-center\"}", "refId": "A", "legendFormat": "duration" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 20,
      "type": "table",
      "title": "media-backup Unit States",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "node_systemd_unit_state{machine_name=\"media-center\", name=~\"media-backup.*\"} == 1", "refId": "A", "instant": true, "format": "table" }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Value": true, "__name__": true, "job": true, "instance": true, "machine_name": true, "namespace": true, "service": true, "endpoint": true },
            "renameByName": { "name": "Unit", "state": "State", "type": "Type" }
          }
        },
        { "id": "sortBy", "options": { "fields": {}, "sort": [{ "field": "Unit" }] } }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    }
  ]
}
