    {
      "id": 14,
      "type": "stat",
      "title": "Proxmox Host (virtuaxi)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "44fd2e18-715d-458e-ab7c-a6b4ecfa6966"
      },
      "targets": [
        {
          "expr": "pve_cpu_usage_ratio{id=\"node/virtuaxi\"}",
          "refId": "A",
          "instant": true,
          "legendFormat": "CPU"
        },
        {
          "expr": "pve_memory_usage_bytes{id=\"node/virtuaxi\"} / pve_memory_size_bytes{id=\"node/virtuaxi\"}",
          "refId": "B",
          "instant": true,
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "orientation": "vertical"
      }
    },
